// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(uuid())
  openId        String    @unique // 微信openId
  unionId       String?   @unique // 微信unionId
  nickname      String?
  avatar        String?
  phone         String?   @unique
  targetExam    String?   // 目标考试类型：国考/省考/事业单位
  targetDate    DateTime? // 目标考试日期
  education     String?   // 学历
  major         String?   // 专业
  politicalStatus String? // 政治面貌
  workYears     Int?      // 工作年限
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联
  practiceRecords PracticeRecord[]
  wrongQuestions  WrongQuestion[]
  studyPlans      StudyPlan[]
  mockExams       MockExam[]
}

// 题目表
model Question {
  id            String    @id @default(uuid())
  source        String    // 题目来源：2024国考/2023省考等
  year          Int       // 年份
  examType      String    // 考试类型：国考/省考/事业单位
  category      String    // 大类：言语理解/数量关系/判断推理/资料分析/常识判断
  subCategory   String?   // 子类：选词填空/片段阅读等
  difficulty    Int       @default(1) // 难度：1-5
  content       String    // 题目内容（JSON格式）
  options       String?   // 选项（JSON字符串）
  answer        String    // 正确答案
  explanation   String?   // 解析
  knowledgePoints String? // 知识点标签(JSON字符串)
  isAiParsed    Boolean   @default(false) // 是否有AI解析
  aiExplanation String?   // AI解析内容(JSON字符串)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联
  practiceRecords PracticeRecord[]
  wrongQuestions  WrongQuestion[]
}

// 刷题记录表
model PracticeRecord {
  id            String    @id @default(uuid())
  userId        String
  questionId    String
  userAnswer    String    // 用户答案
  isCorrect     Boolean   // 是否正确
  timeSpent     Int       // 用时（秒）
  practiceType  String    // 练习类型：quick/special/mock
  createdAt     DateTime  @default(now())
  
  // 关联
  user          User      @relation(fields: [userId], references: [id])
  question      Question  @relation(fields: [questionId], references: [id])
  
  @@index([userId, createdAt])
  @@index([questionId])
}

// 错题本
model WrongQuestion {
  id            String    @id @default(uuid())
  userId        String
  questionId    String
  wrongCount    Int       @default(1) // 错误次数
  lastWrongAt   DateTime  @default(now())
  nextReviewAt  DateTime? // 下次复习时间（艾宾浩斯）
  reviewCount   Int       @default(0) // 复习次数
  mastered      Boolean   @default(false) // 是否已掌握
  userNote      String?   // 用户笔记
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联
  user          User      @relation(fields: [userId], references: [id])
  question      Question  @relation(fields: [questionId], references: [id])
  
  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
}

// 学习计划表
model StudyPlan {
  id            String    @id @default(uuid())
  userId        String
  planType      String    // 计划类型：daily/weekly/phase
  startDate     DateTime
  endDate       DateTime
  tasks         String    // 任务列表（JSON字符串）
  completed     Boolean   @default(false)
  progress      Int       @default(0) // 进度百分比
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联
  user          User      @relation(fields: [userId], references: [id])
  
  @@index([userId, startDate])
}

// 模拟考试记录
model MockExam {
  id            String    @id @default(uuid())
  userId        String
  examType      String    // 考试类型
  duration      Int       @default(120) // 考试时长（分钟）
  questions     String    // 题目ID列表（JSON字符串）
  status        String    @default("in_progress") // 状态：in_progress/completed
  startTime     DateTime? // 开始时间
  endTime       DateTime? // 结束时间
  score         Float?    // 总分
  correctCount  Int?      // 正确题数
  totalCount    Int?      // 总题数
  answers       String?   // 答题详情（JSON字符串）
  categoryStats String?   // 各分类统计（JSON字符串）
  createdAt     DateTime  @default(now())
  
  // 关联
  user          User      @relation(fields: [userId], references: [id])
  
  @@index([userId, createdAt])
}
